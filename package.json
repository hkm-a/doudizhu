{
  "name": "doudizhu-desktop",
  "version": "0.4.0-alpha",
  "private": true,
  "description": "Tauri desktop shell for the svzdev/doudizhu based project.",
  "scripts": {
    "clean:python-cache": "node scripts/clean-python-cache.mjs",
    "verify": "node scripts/verify.mjs",
    "verify:backend": "node scripts/verify.mjs backend",
    "verify:web": "node scripts/verify.mjs web",
    "verify:desktop": "node scripts/verify.mjs desktop",
    "verify:config": "node scripts/verify.mjs config",
    "verify:format": "node scripts/verify.mjs format",
    "verify:release": "node scripts/verify-release-metadata.mjs",
    "desktop:smoke": "node scripts/desktop-startup-smoke.mjs",
    "desktop:artifact-smoke": "node scripts/linux-alpha-artifact-smoke.mjs",
    "desktop:artifact-manifest": "node scripts/linux-alpha-manifest.mjs",
    "desktop:release-bundle": "node scripts/linux-alpha-bundle.mjs",
    "desktop:release-check": "node scripts/linux-alpha-release-check.mjs",
    "ai:summary": "PYTHONPATH=server python3 scripts/ai-decision-summary.py",
    "ai:report": "PYTHONPATH=server python3 scripts/ai-decision-summary.py --html",
    "sounds:placeholders": "python3 scripts/generate-placeholder-sounds.py",
    "sounds:fetch": "python3 scripts/fetch-real-sounds.py",
    "segment:season-reset": "python3 scripts/season_reset_cron.py",
    "segment:badges": "python3 scripts/generate-segment-badges.py",
    "player:summary": "PYTHONPATH=server python3 scripts/player-event-summary.py",
    "player:report": "PYTHONPATH=server python3 scripts/player-event-summary.py --html",
    "player:smoke": "PYTHONPATH=server python3 scripts/player-event-smoke.py",
    "dev:setup": "node scripts/setup-dev.mjs",
    "dev:db": "docker compose up -d mysql",
    "dev:db:down": "docker compose down",
    "dev:doctor": "node scripts/doctor-dev.mjs",
    "dev:ai:setup": "node scripts/download-douzero-model.mjs && node -e \"const m=require('node:fs').readFileSync('.env','utf8').replace('DOUZERO_ENABLED=0','DOUZERO_ENABLED=1'); require('node:fs').writeFileSync('.env',m); console.log('AI ready: DOUZERO_ENABLED=1 set in .env')\"",
    "dev:migrate": "cd server && PYTHONPATH=. python3 ../scripts/run-migrations.py upgrade",
    "dev:migrate:generate": "cd server && PYTHONPATH=. python3 ../scripts/run-migrations.py autogenerate",
    "dev:migrate:check": "cd server && PYTHONPATH=. python3 ../scripts/run-migrations.py check",
    "dev:server": "cd server && PYTHONPATH=. python3 app.py",
    "dev:web": "npm --prefix client start",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "pretauri:build": "npm run clean:python-cache",
    "tauri:build": "tauri build",
    "desktop:server": "cd server && PYTHONPATH=. python3 app.py"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2"
  }
}
