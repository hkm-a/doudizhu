{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "doudizhu",
  "version": "0.4.0-alpha",
  "identifier": "com.local.doudizhu",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "dist",
    "devUrl": "http://127.0.0.1:8081/"
  },
  "app": {
    "windows": [],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "msi", "nsis", "dmg"],
    "resources": {
      "../server": "server",
      "../scripts/backend-preflight.py": "backend-preflight.py",
      "../requirements.txt": "requirements.txt",
      "../schema.sql": "schema.sql"
    },
    "linux": {
      "deb": {
        "depends": ["python3", "python3-venv", "mysql-server"]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "windows": {
      "wix": {
        "language": "zh-CN"
      }
    },
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
